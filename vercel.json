{
    "version": 2,
    "functions": {
        "api/*.js": {
            "runtime": "nodejs18.x"
        }
    },
    "builds": [
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "css/*.css",
            "use": "@vercel/static"
        },
        {
            "src": "js/*.js",
            "use": "@vercel/static"
        },
        {
            "src": "blog/*.html",
            "use": "@vercel/static"
        },
        {
            "src": "assets/**/*",
            "use": "@vercel/static"
        }
    ]
}